<?xml version="1.0" encoding="utf-8"?>
<mxfile host="Electron">
  <diagram name="Velicor and Beacon Integration" id="integration-architecture-diag">
    <mxGraphModel dx="1710" dy="788" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="850" pageHeight="1100" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        
        <!-- Vertices -->
        <mxCell id="user-service" parent="1" style="rounded=1;whiteSpace=wrap;html=1;strokeWidth=2;fontSize=14;fontStyle=1;fillColor=#e7f5ff;strokeColor=#1c7ed6;fontColor=#0b7285;" value="User Application Service&lt;br/&gt;(e.g., Nexus Blog Backend)&lt;br/&gt;- Centralizes logging&lt;br/&gt;- Dispatches alert events" vertex="1">
          <mxGeometry height="90" width="220" x="80" y="350" as="geometry" />
        </mxCell>
        
        <mxCell id="beacon-service" parent="1" style="rounded=1;whiteSpace=wrap;html=1;strokeWidth=2;fontSize=14;fontStyle=1;fillColor=#e3fafc;strokeColor=#0c8599;fontColor=#0b7285;" value="Beacon Notification Engine&lt;br/&gt;(Fastify Pub/Sub Server)&lt;br/&gt;- Real-time WebSocket/SSE&lt;br/&gt;- Webhook delivery queues&lt;br/&gt;- Logs internally to Velicor" vertex="1">
          <mxGeometry height="110" width="240" x="420" y="200" as="geometry" />
        </mxCell>
        
        <mxCell id="velicor-service" parent="1" style="rounded=1;whiteSpace=wrap;html=1;strokeWidth=2;fontSize=14;fontStyle=1;fillColor=#fff5f5;strokeColor=#fa5252;fontColor=#e03131;" value="Velicor Log Aggregator&lt;br/&gt;(FastAPI Ingestion Server)&lt;br/&gt;- Asynchronous batch receiver&lt;br/&gt;- Analyzes and parses logs&lt;br/&gt;- Triggers webhooks on alert rules" vertex="1">
          <mxGeometry height="110" width="240" x="420" y="490" as="geometry" />
        </mxCell>
        
        <mxCell id="alert-receivers" parent="1" style="rounded=1;whiteSpace=wrap;html=1;strokeWidth=2;fontSize=14;fontStyle=1;fillColor=#ebfbee;strokeColor=#2b8a3e;fontColor=#2b8a3e;" value="Subscribers &amp;amp; Webhooks&lt;br/&gt;(Browsers, CLI, Slack)&lt;br/&gt;- Real-time incident logs" vertex="1">
          <mxGeometry height="80" width="220" x="780" y="215" as="geometry" />
        </mxCell>
        
        <mxCell id="velicor-db" parent="1" style="shape=cylinder;whiteSpace=wrap;html=1;boundedLbl=1;backgroundOutline=1;strokeWidth=2;fontSize=14;fontStyle=1;fillColor=#e5dbff;strokeColor=#5f3dc4;fontColor=#5f3dc4;" value="PostgreSQL Storage&lt;br/&gt;- Isolated log tables&lt;br/&gt;- GIN Indexes &amp;amp; RLS policies" vertex="1">
          <mxGeometry height="90" width="200" x="790" y="500" as="geometry" />
        </mxCell>
        
        <!-- Edges -->
